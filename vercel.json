{
  "version": 2,
  "builds": [
    {
      "src": "backend/src/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "frontend/public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/health",                    "dest": "backend/src/server.js" },
    { "src": "/auth/(.*)",                 "dest": "backend/src/server.js" },
    { "src": "/patients/(.*)",             "dest": "backend/src/server.js" },
    { "src": "/upload/(.*)",               "dest": "backend/src/server.js" },
    { "src": "/api/(.*)",                  "dest": "backend/src/server.js" },

    { "src": "/sw.js",                     "dest": "frontend/public/sw.js" },
    { "src": "/manifest.json",             "dest": "frontend/public/manifest.json" },
    { "src": "/favicon.ico",               "dest": "frontend/public/favicon.ico" },
    { "src": "/icon-(.*)",                 "dest": "frontend/public/icon-$1" },
    { "src": "/og-image.png",              "dest": "frontend/public/og-image.png" },
    { "src": "/css/(.*)",                  "dest": "frontend/public/css/$1" },
    { "src": "/js/(.*)",                   "dest": "frontend/public/js/$1" },
    { "src": "/app.html",                  "dest": "frontend/public/app.html" },
    { "src": "/upload.html",               "dest": "frontend/public/upload.html" },
    { "src": "/index.html",                "dest": "frontend/public/index.html" },
    { "src": "/",                          "dest": "frontend/public/index.html" },

    { "src": "/(.*)",                      "dest": "backend/src/server.js" }
  ],
  "headers": [
    {
      "source": "/(.*)\\.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Pragma", "value": "no-cache" }
      ]
    },
    {
      "source": "/(.*)\\.css",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, must-revalidate" }
      ]
    },
    {
      "source": "/(.*)\\.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, must-revalidate" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data:; font-src 'self' https://fonts.gstatic.com; connect-src 'self' https://*.supabase.co;"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=31536000; includeSubDomains"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    }
  ]
}
