{
  "version": 2,
  "builds": [
    {
      "src": "backend/src/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "frontend/public/**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/health",                    "dest": "backend/src/server.js" },
    { "src": "/auth/(.*)",                 "dest": "backend/src/server.js" },
    { "src": "/patients/(.*)",             "dest": "backend/src/server.js" },
    { "src": "/upload/(.*)",               "dest": "backend/src/server.js" },
    { "src": "/api/(.*)",                  "dest": "backend/src/server.js" },
    { "src": "/(.*)",                      "dest": "backend/src/server.js" }
  ]
}
