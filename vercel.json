{
  "version": 2,
  "builds": [
    {
      "src": "backend/src/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "frontend/public/**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/health",                    "dest": "backend/src/server.js" },
    { "src": "/auth/(.*)",                 "dest": "backend/src/server.js" },
    { "src": "/patients/(.*)",             "dest": "backend/src/server.js" },
    { "src": "/upload/(.*)",               "dest": "backend/src/server.js" },
    { "src": "/api/(.*)",                  "dest": "backend/src/server.js" },
    { "src": "/(.*)",                      "dest": "backend/src/server.js" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self' https: data:; script-src 'self' 'unsafe-inline' https:; style-src 'self' 'unsafe-inline' https:; img-src 'self' data: https:; font-src 'self' https:; connect-src 'self' https:;"
        }
      ]
    }
  ]
}
