# Variáveis de Ambiente — ClinicRC

# COPIE este arquivo para .env e preencha com valores reais
# NUNCA commite o arquivo .env no GitHub!

# ── SEGURANÇA ──────────────────────────────────────────
# Chave secreta para assinar tokens JWT (use algo longo e aleatório)
JWT_SECRET=mude_esta_chave_para_algo_secreto_longo_aqui_2024

# ── USUÁRIO ADMIN PADRÃO (criado no primeiro boot) ─────
ADMIN_USER=admin
ADMIN_PASS=mude_a_senha_aqui

# ── SUPORTE ──────────────────────────────────────────────
# Link do seu WhatsApp (substitua pelo número real)
# Formato: https://wa.me/55DDNÚMERO (sem espaços, parênteses ou traços)
WHATSAPP_SUPPORT=https://wa.me/5581999999999

# ── SERVIDOR ─────────────────────────────────────────────
# Porta local (Railway define automaticamente em produção)
PORT=3000

# ── CORS (opcional) ──────────────────────────────────────
# Em produção, coloque o domínio exato do seu app Railway
# CORS_ORIGIN=https://clinicrc.up.railway.app
