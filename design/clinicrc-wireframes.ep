<Page id="pg_modal_lead" name="06 - Modal Lead" width="500" height="700" backgroundColor="#00000066"
      note="Modal fullscreen overlay (.mbg). Adicionar ou editar lead. Campos: nome (required), telefone (required), procedimento, valor, origem (select), temperatura (select), estrategia (select), observacoes (textarea). Max-height 60vh scroll.">
