<?xml version="1.0"?>
<Document xmlns="http://www.evolus.vn/Namespace/Pencil"
          xmlns:p="http://www.evolus.vn/Namespace/Pencil"
          xmlns:svg="http://www.w3.org/2000/svg"
          xmlns:xlink="http://www.w3.org/1999/xlink">

<Properties>
  <Property name="activePageId">pg_kanban</Property>
</Properties>

<!-- ============================================================ -->
<!--  PAGE 1: LOGIN                                                -->
<!-- ============================================================ -->
<Page id="pg_login" name="01 - Login" width="1440" height="900" backgroundColor="#F3F4F6"
      note="Tela de autenticacao Supabase Auth. Email + senha. Multi-tenant: cada clinica isolada por clinic_id.">
  <Content>
    <!-- Background -->
    <p:Shape type="Builtin:RoundedRect" id="login_bg" locked="false">
      <p:Property name="box">0,0,1440,900</p:Property>
      <p:Property name="fillColor">#F3F4F6</p:Property>
    </p:Shape>

    <!-- Login Card -->
    <p:Shape type="Builtin:RoundedRect" id="login_card" locked="false">
      <p:Property name="box">470,200,500,420</p:Property>
      <p:Property name="fillColor">#FFFFFF</p:Property>
      <p:Property name="strokeColor">#E5E7EB</p:Property>
      <p:Property name="radius">12</p:Property>
      <p:Property name="shadow">true</p:Property>
    </p:Shape>

    <!-- Logo Area -->
    <p:Shape type="Builtin:PlainText" id="login_logo">
      <p:Property name="box">620,230,200,40</p:Property>
      <p:Property name="textContent">ClinicRC</p:Property>
      <p:Property name="textFont">Bold 24px sans-serif</p:Property>
      <p:Property name="textColor">#EC6726</p:Property>
      <p:Property name="textAlign">center</p:Property>
    </p:Shape>

    <p:Shape type="Builtin:PlainText" id="login_subtitle">
      <p:Property name="box">570,270,300,20</p:Property>
      <p:Property name="textContent">CRM Odontologico</p:Property>
      <p:Property name="textFont">14px sans-serif</p:Property>
      <p:Property name="textColor">#6B7280</p:Property>
      <p:Property name="textAlign">center</p:Property>
    </p:Shape>

    <!-- Email Field -->
    <p:Shape type="Builtin:PlainText" id="login_email_label">
      <p:Property name="box">520,320,100,16</p:Property>
      <p:Property name="textContent">Email</p:Property>
      <p:Property name="textFont">600 12px sans-serif</p:Property>
      <p:Property name="textColor">#374151</p:Property>
    </p:Shape>
    <p:Shape type="Builtin:RoundedRect" id="login_email_input">
      <p:Property name="box">520,340,400,40</p:Property>
      <p:Property name="fillColor">#F9FAFB</p:Property>
      <p:Property name="strokeColor">#D1D5DB</p:Property>
      <p:Property name="radius">6</p:Property>
    </p:Shape>
    <p:Shape type="Builtin:PlainText" id="login_email_placeholder">
      <p:Property name="box">532,350,200,20</p:Property>
      <p:Property name="textContent">clinica@email.com</p:Property>
      <p:Property name="textFont">13px sans-serif</p:Property>
      <p:Property name="textColor">#9CA3AF</p:Property>
    </p:Shape>

    <!-- Password Field -->
    <p:Shape type="Builtin:PlainText" id="login_pass_label">
      <p:Property name="box">520,400,100,16</p:Property>
      <p:Property name="textContent">Senha</p:Property>
      <p:Property name="textFont">600 12px sans-serif</p:Property>
      <p:Property name="textColor">#374151</p:Property>
    </p:Shape>
    <p:Shape type="Builtin:RoundedRect" id="login_pass_input">
      <p:Property name="box">520,420,400,40</p:Property>
      <p:Property name="fillColor">#F9FAFB</p:Property>
      <p:Property name="strokeColor">#D1D5DB</p:Property>
      <p:Property name="radius">6</p:Property>
    </p:Shape>

    <!-- Login Button -->
    <p:Shape type="Builtin:RoundedRect" id="login_btn">
      <p:Property name="box">520,490,400,44</p:Property>
      <p:Property name="fillColor">#EC6726</p:Property>
      <p:Property name="strokeColor">#EC6726</p:Property>
      <p:Property name="radius">6</p:Property>
    </p:Shape>
    <p:Shape type="Builtin:PlainText" id="login_btn_text">
      <p:Property name="box">520,500,400,24</p:Property>
      <p:Property name="textContent">Entrar</p:Property>
      <p:Property name="textFont">600 14px sans-serif</p:Property>
      <p:Property name="textColor">#FFFFFF</p:Property>
      <p:Property name="textAlign">center</p:Property>
    </p:Shape>

    <!-- Footer -->
    <p:Shape type="Builtin:PlainText" id="login_footer">
      <p:Property name="box">520,560,400,16</p:Property>
      <p:Property name="textContent">Esqueceu a senha? Contate o suporte</p:Property>
      <p:Property name="textFont">12px sans-serif</p:Property>
      <p:Property name="textColor">#9CA3AF</p:Property>
      <p:Property name="textAlign">center</p:Property>
    </p:Shape>
  </Content>
</Page>

<!-- ============================================================ -->
<!--  PAGE 2: CRM KANBAN (pg0) - MAIN SCREEN                     -->
<!-- ============================================================ -->
<Page id="pg_kanban" name="02 - CRM Kanban (pg0)" width="1440" height="900" backgroundColor="#F3F4F6"
      note="Layout split: Script (38%) | Resizer | Kanban (62%). Header fixo com 4 tabs. Colunas dinamicas (clinic_settings.kanban_columns). Filtros por procedimento, temperatura, origem, estrategia.">
  <Content>
    <!-- RGB Top Bar -->
    <p:Shape type="Builtin:RoundedRect" id="rgb_bar">
      <p:Property name="box">0,0,1440,3</p:Property>
      <p:Property name="fillColor">#EC6726</p:Property>
      <p:Property name="note">Barra RGB animada gradient - 4 cores customizaveis via modal personalizar</p:Property>
    </p:Shape>

    <!-- Header -->
    <p:Shape type="Builtin:RoundedRect" id="header">
      <p:Property name="box">0,3,1440,56</p:Property>
      <p:Property name="fillColor">#FFFFFF</p:Property>
      <p:Property name="strokeColor">#E5E7EB</p:Property>
      <p:Property name="note">Header fixo. z-index 2000. Shadow bottom.</p:Property>
    </p:Shape>

    <!-- Header Tabs -->
    <p:Shape type="Builtin:RoundedRect" id="tab_crm">
      <p:Property name="box">20,11,140,40</p:Property>
      <p:Property name="fillColor">#FFF7ED</p:Property>
      <p:Property name="strokeColor">#EC6726</p:Property>
      <p:Property name="radius">8</p:Property>
    </p:Shape>
    <p:Shape type="Builtin:PlainText" id="tab_crm_text">
      <p:Property name="box">20,21,140,20</p:Property>
      <p:Property name="textContent">[view_kanban] CRM</p:Property>
      <p:Property name="textFont">600 12px sans-serif</p:Property>
      <p:Property name="textColor">#EC6726</p:Property>
      <p:Property name="textAlign">center</p:Property>
    </p:Shape>

    <p:Shape type="Builtin:PlainText" id="tab_rel_text">
      <p:Property name="box">170,21,140,20</p:Property>
      <p:Property name="textContent">[analytics] Relatorios</p:Property>
      <p:Property name="textFont">500 12px sans-serif</p:Property>
      <p:Property name="textColor">#6B7280</p:Property>
      <p:Property name="textAlign">center</p:Property>
    </p:Shape>

    <p:Shape type="Builtin:PlainText" id="tab_odonto_text">
      <p:Property name="box">320,21,140,20</p:Property>
      <p:Property name="textContent">[dentistry] Odontograma</p:Property>
      <p:Property name="textFont">500 12px sans-serif</p:Property>
      <p:Property name="textColor">#6B7280</p:Property>
      <p:Property name="textAlign">center</p:Property>
    </p:Shape>

    <p:Shape type="Builtin:PlainText" id="tab_config_text">
      <p:Property name="box">470,21,140,20</p:Property>
      <p:Property name="textContent">[settings] Config</p:Property>
      <p:Property name="textFont">500 12px sans-serif</p:Property>
      <p:Property name="textColor">#6B7280</p:Property>
      <p:Property name="textAlign">center</p:Property>
    </p:Shape>

    <!-- Header Right: clock, avatar, sync, support -->
    <p:Shape type="Builtin:PlainText" id="hdr_clock">
      <p:Property name="box">1200,21,60,20</p:Property>
      <p:Property name="textContent">14:35</p:Property>
      <p:Property name="textFont">500 12px sans-serif</p:Property>
      <p:Property name="textColor">#6B7280</p:Property>
    </p:Shape>
    <p:Shape type="Builtin:Ellipse" id="hdr_bell">
      <p:Property name="box">1280,16,30,30</p:Property>
      <p:Property name="fillColor">#F3F4F6</p:Property>
      <p:Property name="strokeColor">#E5E7EB</p:Property>
      <p:Property name="note">[notifications] Bell icon + badge count</p:Property>
    </p:Shape>
    <p:Shape type="Builtin:Ellipse" id="hdr_avatar">
      <p:Property name="box">1330,13,36,36</p:Property>
      <p:Property name="fillColor">#EC6726</p:Property>
      <p:Property name="note">Avatar iniciais usuario + logout dropdown</p:Property>
    </p:Shape>

    <!-- === SCRIPT PANEL (Left 38%) === -->
    <p:Shape type="Builtin:RoundedRect" id="script_panel">
      <p:Property name="box">0,59,540,841</p:Property>
      <p:Property name="fillColor">#FFFFFF</p:Property>
      <p:Property name="strokeColor">#E5E7EB</p:Property>
      <p:Property name="note">Script Panel (.sp) - 38% width. Contains: header, attempt toolbar, patient bar, script body (markdown rendered).</p:Property>
    </p:Shape>

    <!-- Script Header -->
    <p:Shape type="Builtin:PlainText" id="sp_title">
      <p:Property name="box">20,75,100,20</p:Property>
      <p:Property name="textContent">Roteiro</p:Property>
      <p:Property name="textFont">700 16px sans-serif</p:Property>
      <p:Property name="textColor">#1F2937</p:Property>
    </p:Shape>
    <p:Shape type="Builtin:PlainText" id="sp_subtitle">
      <p:Property name="box">20,98,300,14</p:Property>
      <p:Property name="textContent">Selecione a tentativa e clique no paciente</p:Property>
      <p:Property name="textFont">12px sans-serif</p:Property>
      <p:Property name="textColor">#9CA3AF</p:Property>
    </p:Shape>

    <!-- Attempt Toolbar -->
    <p:Shape type="Builtin:RoundedRect" id="tbar">
      <p:Property name="box">10,125,520,36</p:Property>
      <p:Property name="fillColor">#F8FAFC</p:Property>
      <p:Property name="strokeColor">#E2E8F0</p:Property>
      <p:Property name="radius">6</p:Property>
      <p:Property name="note">Toolbar de tentativas. Botoes: 1a, 2a, 3a tentativa. Destaque na selecionada.</p:Property>
    </p:Shape>
    <p:Shape type="Builtin:PlainText" id="tbar_label">
      <p:Property name="box">20,133,80,20</p:Property>
      <p:Property name="textContent">TENTATIVA:</p:Property>
      <p:Property name="textFont">700 10px sans-serif</p:Property>
      <p:Property name="textColor">#6B7280</p:Property>
    </p:Shape>
    <p:Shape type="Builtin:RoundedRect" id="tbar_btn1">
      <p:Property name="box">110,130,50,26</p:Property>
      <p:Property name="fillColor">#EC6726</p:Property>
      <p:Property name="radius">4</p:Property>
    </p:Shape>
    <p:Shape type="Builtin:PlainText" id="tbar_btn1_t">
      <p:Property name="box">110,135,50,16</p:Property>
      <p:Property name="textContent">1a</p:Property>
      <p:Property name="textFont">600 11px sans-serif</p:Property>
      <p:Property name="textColor">#FFFFFF</p:Property>
      <p:Property name="textAlign">center</p:Property>
    </p:Shape>
    <p:Shape type="Builtin:RoundedRect" id="tbar_btn2">
      <p:Property name="box">168,130,50,26</p:Property>
      <p:Property name="fillColor">#F3F4F6</p:Property>
      <p:Property name="strokeColor">#D1D5DB</p:Property>
      <p:Property name="radius">4</p:Property>
    </p:Shape>
    <p:Shape type="Builtin:PlainText" id="tbar_btn2_t">
      <p:Property name="box">168,135,50,16</p:Property>
      <p:Property name="textContent">2a</p:Property>
      <p:Property name="textFont">600 11px sans-serif</p:Property>
      <p:Property name="textColor">#6B7280</p:Property>
      <p:Property name="textAlign">center</p:Property>
    </p:Shape>

    <!-- Patient Bar -->
    <p:Shape type="Builtin:RoundedRect" id="pbar">
      <p:Property name="box">10,170,520,36</p:Property>
      <p:Property name="fillColor">#FFF7ED</p:Property>
      <p:Property name="strokeColor">#FED7AA</p:Property>
      <p:Property name="radius">6</p:Property>
      <p:Property name="note">Barra do paciente selecionado. Mostra nome + telefone + procedimento.</p:Property>
    </p:Shape>
    <p:Shape type="Builtin:PlainText" id="pbar_text">
      <p:Property name="box">20,178,400,20</p:Property>
      <p:Property name="textContent">Maria Silva | (11) 99999-0000 | Implante</p:Property>
      <p:Property name="textFont">500 12px sans-serif</p:Property>
      <p:Property name="textColor">#92400E</p:Property>
    </p:Shape>

    <!-- Script Body -->
    <p:Shape type="Builtin:RoundedRect" id="sbody">
      <p:Property name="box">10,220,520,670</p:Property>
      <p:Property name="fillColor">#FFFFFF</p:Property>
      <p:Property name="strokeColor">#F3F4F6</p:Property>
      <p:Property name="note">Area de conteudo do roteiro renderizado em Markdown. Suporta variaveis dinamicas (#nome, #procedimento, #valor, #promo). Editavel via textarea toggle.</p:Property>
    </p:Shape>
    <p:Shape type="Builtin:PlainText" id="sbody_sample">
      <p:Property name="box">25,240,490,100</p:Property>
      <p:Property name="textContent">Ola Maria!

Estou ligando da Clinica ABC sobre o procedimento de Implante que conversamos.

Temos uma condicao especial: de R$ 3.000 por R$ 2.100 (30% OFF).

Gostaria de agendar?</p:Property>
      <p:Property name="textFont">13px sans-serif</p:Property>
      <p:Property name="textColor">#374151</p:Property>
    </p:Shape>

    <!-- === RESIZER === -->
    <p:Shape type="Builtin:RoundedRect" id="resizer">
      <p:Property name="box">540,59,6,841</p:Property>
      <p:Property name="fillColor">#E5E7EB</p:Property>
      <p:Property name="note">Resizer draggable. cursor: col-resize. Hover: var(--cp).</p:Property>
    </p:Shape>

    <!-- === KANBAN PANEL (Right 62%) === -->
    <p:Shape type="Builtin:RoundedRect" id="kanban_panel">
      <p:Property name="box">546,59,894,841</p:Property>
      <p:Property name="fillColor">#F3F4F6</p:Property>
      <p:Property name="note">Kanban Panel (.kp). Contains: toolbar (search + filters + add), counter header, columns.</p:Property>
    </p:Shape>

    <!-- Kanban Toolbar -->
    <p:Shape type="Builtin:RoundedRect" id="ktb_search">
      <p:Property name="box">556,69,300,36</p:Property>
      <p:Property name="fillColor">#FFFFFF</p:Property>
      <p:Property name="strokeColor">#D1D5DB</p:Property>
      <p:Property name="radius">6</p:Property>
      <p:Property name="note">Input busca: #searchPatient. Filtra cards por nome/telefone/procedimento.</p:Property>
    </p:Shape>
    <p:Shape type="Builtin:PlainText" id="ktb_search_ph">
      <p:Property name="box">576,77,200,20</p:Property>
      <p:Property name="textContent">[search] Buscar paciente...</p:Property>
      <p:Property name="textFont">12px sans-serif</p:Property>
      <p:Property name="textColor">#9CA3AF</p:Property>
    </p:Shape>

    <!-- Toggle buttons -->
    <p:Shape type="Builtin:RoundedRect" id="ktb_toggle_script">
      <p:Property name="box">870,69,80,36</p:Property>
      <p:Property name="fillColor">#F8FAFC</p:Property>
      <p:Property name="strokeColor">#E2E8F0</p:Property>
      <p:Property name="radius">6</p:Property>
      <p:Property name="note">Toggle Script panel visibility</p:Property>
    </p:Shape>
    <p:Shape type="Builtin:RoundedRect" id="ktb_toggle_filter">
      <p:Property name="box">958,69,80,36</p:Property>
      <p:Property name="fillColor">#F8FAFC</p:Property>
      <p:Property name="strokeColor">#E2E8F0</p:Property>
      <p:Property name="radius">6</p:Property>
      <p:Property name="note">Toggle Filter panel visibility</p:Property>
    </p:Shape>

    <!-- Add Lead Button -->
    <p:Shape type="Builtin:RoundedRect" id="ktb_add_lead">
      <p:Property name="box">1340,69,90,36</p:Property>
      <p:Property name="fillColor">#F1F8F2</p:Property>
      <p:Property name="strokeColor">#C8E6CA</p:Property>
      <p:Property name="radius">6</p:Property>
    </p:Shape>
    <p:Shape type="Builtin:PlainText" id="ktb_add_lead_t">
      <p:Property name="box">1340,77,90,20</p:Property>
      <p:Property name="textContent">[+] Lead</p:Property>
      <p:Property name="textFont">600 11px sans-serif</p:Property>
      <p:Property name="textColor">#2E7D32</p:Property>
      <p:Property name="textAlign">center</p:Property>
    </p:Shape>

    <!-- Counter Header -->
    <p:Shape type="Builtin:RoundedRect" id="kmini">
      <p:Property name="box">556,115,884,28</p:Property>
      <p:Property name="fillColor">#FFFFFF</p:Property>
      <p:Property name="strokeColor">#E5E7EB</p:Property>
      <p:Property name="radius">6</p:Property>
      <p:Property name="note">Mini contadores por coluna. Atualizam dinamicamente.</p:Property>
    </p:Shape>

    <!-- === KANBAN COLUMNS === -->
    <!-- Column 1: Ligar -->
    <p:Shape type="Builtin:RoundedRect" id="col_ligar">
      <p:Property name="box">556,150,216,740</p:Property>
      <p:Property name="fillColor">#FFFFFF</p:Property>
      <p:Property name="strokeColor">#E5E7EB</p:Property>
      <p:Property name="radius">8</p:Property>
    </p:Shape>
    <p:Shape type="Builtin:RoundedRect" id="col_ligar_hd">
      <p:Property name="box">556,150,216,40</p:Property>
      <p:Property name="fillColor">#FAFAFA</p:Property>
      <p:Property name="radius">8</p:Property>
    </p:Shape>
    <p:Shape type="Builtin:PlainText" id="col_ligar_t">
      <p:Property name="box">570,160,140,20</p:Property>
      <p:Property name="textContent">Ligar</p:Property>
      <p:Property name="textFont">700 13px sans-serif</p:Property>
      <p:Property name="textColor">#1F2937</p:Property>
    </p:Shape>
    <p:Shape type="Builtin:Ellipse" id="col_ligar_badge">
      <p:Property name="box">740,155,24,24</p:Property>
      <p:Property name="fillColor">#3B82F6</p:Property>
      <p:Property name="note">Badge com contagem de cards</p:Property>
    </p:Shape>

    <!-- Sample Card in Ligar -->
    <p:Shape type="Builtin:RoundedRect" id="card_sample">
      <p:Property name="box">564,200,200,320</p:Property>
      <p:Property name="fillColor">#FFFFFF</p:Property>
      <p:Property name="strokeColor">#E5E7EB</p:Property>
      <p:Property name="radius">8</p:Property>
      <p:Property name="shadow">true</p:Property>
      <p:Property name="note">Card do Kanban. Selecionavel (onclick seleciona paciente para script). Anatomia completa abaixo.</p:Property>
    </p:Shape>
    <p:Shape type="Builtin:PlainText" id="card_nome">
      <p:Property name="box">574,210,140,16</p:Property>
      <p:Property name="textContent">Maria Silva</p:Property>
      <p:Property name="textFont">700 13px sans-serif</p:Property>
      <p:Property name="textColor">#1F2937</p:Property>
    </p:Shape>
    <p:Shape type="Builtin:PlainText" id="card_tel">
      <p:Property name="box">574,230,140,14</p:Property>
      <p:Property name="textContent">[phone] (11) 99999-0000</p:Property>
      <p:Property name="textFont">12px sans-serif</p:Property>
      <p:Property name="textColor">#6B7280</p:Property>
    </p:Shape>
    <p:Shape type="Builtin:RoundedRect" id="card_proc">
      <p:Property name="box">574,250,80,20</p:Property>
      <p:Property name="fillColor">#EFF6FF</p:Property>
      <p:Property name="radius">3</p:Property>
    </p:Shape>
    <p:Shape type="Builtin:PlainText" id="card_proc_t">
      <p:Property name="box">574,253,80,14</p:Property>
      <p:Property name="textContent">Implante</p:Property>
      <p:Property name="textFont">600 10px sans-serif</p:Property>
      <p:Property name="textColor">#3B82F6</p:Property>
      <p:Property name="textAlign">center</p:Property>
    </p:Shape>
    <p:Shape type="Builtin:PlainText" id="card_valor">
      <p:Property name="box">574,276,100,16</p:Property>
      <p:Property name="textContent">R$ 3.000,00</p:Property>
      <p:Property name="textFont">700 13px sans-serif</p:Property>
      <p:Property name="textColor">#2E7D32</p:Property>
    </p:Shape>

    <!-- Badges row -->
    <p:Shape type="Builtin:RoundedRect" id="card_badge_temp">
      <p:Property name="box">574,298,50,18</p:Property>
      <p:Property name="fillColor">#FEF2F2</p:Property>
      <p:Property name="strokeColor">#FECACA</p:Property>
      <p:Property name="radius">9</p:Property>
    </p:Shape>
    <p:Shape type="Builtin:PlainText" id="card_badge_temp_t">
      <p:Property name="box">574,301,50,12</p:Property>
      <p:Property name="textContent">Quente</p:Property>
      <p:Property name="textFont">600 9px sans-serif</p:Property>
      <p:Property name="textColor">#DC2626</p:Property>
      <p:Property name="textAlign">center</p:Property>
    </p:Shape>
    <p:Shape type="Builtin:RoundedRect" id="card_badge_src">
      <p:Property name="box">630,298,70,18</p:Property>
      <p:Property name="fillColor">#FFFFFF</p:Property>
      <p:Property name="strokeColor">#10B981</p:Property>
      <p:Property name="radius">9</p:Property>
    </p:Shape>
    <p:Shape type="Builtin:PlainText" id="card_badge_src_t">
      <p:Property name="box">630,301,70,12</p:Property>
      <p:Property name="textContent">WhatsApp</p:Property>
      <p:Property name="textFont">600 9px sans-serif</p:Property>
      <p:Property name="textColor">#10B981</p:Property>
      <p:Property name="textAlign">center</p:Property>
    </p:Shape>

    <!-- Tentativas dots -->
    <p:Shape type="Builtin:PlainText" id="card_tent_label">
      <p:Property name="box">574,324,40,12</p:Property>
      <p:Property name="textContent">TENT.:</p:Property>
      <p:Property name="textFont">700 9px sans-serif</p:Property>
      <p:Property name="textColor">#6B7280</p:Property>
