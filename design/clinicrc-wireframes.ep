<!--  PAGE 4: ODONTOGRAMA (pg2)                                   -->
<!-- ============================================================ -->
<Page id="pg_odontograma" name="04 - Odontograma (pg2)" width="1440" height="900" backgroundColor="#F3F4F6"
      note="Grid 1.5fr 1fr. Odontograma SVG (FDI, 32 dentes permanentes + 20 deciduos, 5 faces clicaveis, ciclo saudavel/carie/restaurado/ausente). Procedimentos em aberto com total financeiro.">
  <Content>
    <!-- Header -->
    <p:Shape type="Builtin:RoundedRect" id="odonto_header">
      <p:Property name="box">0,0,1440,59</p:Property>
      <p:Property name="fillColor">#FFFFFF</p:Property>
      <p:Property name="strokeColor">#E5E7EB</p:Property>
    </p:Shape>

    <!-- Page Title -->
    <p:Shape type="Builtin:PlainText" id="odonto_title">
      <p:Property name="box">40,80,400,24</p:Property>
      <p:Property name="textContent">[dentistry] Odontograma Clinico — Maria Silva</p:Property>
      <p:Property name="textFont">600 16px sans-serif</p:Property>
      <p:Property name="textColor">#1F2937</p:Property>
    </p:Shape>

    <!-- Back button -->
    <p:Shape type="Builtin:RoundedRect" id="odonto_back">
      <p:Property name="box">1300,76,100,32</p:Property>
      <p:Property name="fillColor">#F3F4F6</p:Property>
      <p:Property name="strokeColor">#D1D5DB</p:Property>
      <p:Property name="radius">6</p:Property>
    </p:Shape>
    <p:Shape type="Builtin:PlainText" id="odonto_back_t">
      <p:Property name="box">1300,82,100,20</p:Property>
      <p:Property name="textContent">[arrow_back] Kanban</p:Property>
      <p:Property name="textFont">500 12px sans-serif</p:Property>
      <p:Property name="textColor">#6B7280</p:Property>
      <p:Property name="textAlign">center</p:Property>
    </p:Shape>

    <!-- === ODONTOGRAM CARD === -->
    <p:Shape type="Builtin:RoundedRect" id="odonto_card">
      <p:Property name="box">40,120,860,740</p:Property>
      <p:Property name="fillColor">#FFFFFF</p:Property>
      <p:Property name="strokeColor">#E5E7EB</p:Property>
      <p:Property name="radius">12</p:Property>
    </p:Shape>

    <!-- Legend -->
    <p:Shape type="Builtin:RoundedRect" id="legend">
      <p:Property name="box">60,140,800,30</p:Property>
      <p:Property name="fillColor">#F8FAFC</p:Property>
      <p:Property name="radius">6</p:Property>
    </p:Shape>
    <p:Shape type="Builtin:PlainText" id="legend_items">
      <p:Property name="box">80,147,700,16</p:Property>
      <p:Property name="textContent">[branco] Saudavel    [vermelho] Carie    [azul] Restaurado    [cinza] Ausente</p:Property>
      <p:Property name="textFont">500 11px sans-serif</p:Property>
      <p:Property name="textColor">#64748B</p:Property>
    </p:Shape>

    <!-- Arcada Permanente Title -->
    <p:Shape type="Builtin:PlainText" id="arc_perm_title">
      <p:Property name="box">60,185,200,16</p:Property>
      <p:Property name="textContent">Permanentes</p:Property>
      <p:Property name="textFont">700 12px sans-serif</p:Property>
      <p:Property name="textColor">#94A3B8</p:Property>
    </p:Shape>

    <!-- Upper Arch (16 teeth: 18-11 | 21-28) -->
    <p:Shape type="Builtin:RoundedRect" id="arch_upper">
      <p:Property name="box">60,205,800,140</p:Property>
      <p:Property name="fillColor">#FFFFFF</p:Property>
      <p:Property name="note">Arcada superior permanente. 16 dentes (18-11 | 21-28). Cada dente: numero em cima, grid 5 faces no meio, silhueta anatomica embaixo. Midline entre 11 e 21.</p:Property>
    </p:Shape>
    <!-- Tooth placeholders (8 left + midline + 8 right) -->
    <p:Shape type="Builtin:PlainText" id="teeth_upper_nums">
      <p:Property name="box">70,208,780,14</p:Property>
      <p:Property name="textContent">18   17   16   15   14   13   12   11   |   21   22   23   24   25   26   27   28</p:Property>
      <p:Property name="textFont">700 10px monospace</p:Property>
      <p:Property name="textColor">#64748B</p:Property>
      <p:Property name="textAlign">center</p:Property>
    </p:Shape>
    <!-- 5-face grids (represented as small squares) -->
    <p:Shape type="Builtin:RoundedRect" id="face_grid_sample">
      <p:Property name="box">70,228,780,30</p:Property>
      <p:Property name="fillColor">#F8FAFC</p:Property>
      <p:Property name="strokeColor">#CBD5E1</p:Property>
      <p:Property name="radius">4</p:Property>
      <p:Property name="note">Zona dos grids 5-faces. Cada dente tem SVG 24x24 com 5 regioes clicaveis: T(vestibular), B(lingual), L(mesial), R(distal), C(oclusal/incisal). Click cycles: saudavel > carie > restaurado.</p:Property>
    </p:Shape>
    <!-- Anatomy silhouettes -->
    <p:Shape type="Builtin:RoundedRect" id="anat_upper">
      <p:Property name="box">70,264,780,70</p:Property>
      <p:Property name="fillColor">#FAFAFA</p:Property>
      <p:Property name="note">Silhuetas anatomicas SVG extraidas do Figma. 32 symbols unicos (#anat-11 a #anat-48). Cada um com viewBox proprio.</p:Property>
    </p:Shape>

    <!-- Separator -->
    <p:Shape type="Builtin:RoundedRect" id="arch_separator">
      <p:Property name="box">120,350,680,1</p:Property>
      <p:Property name="fillColor">#E2E8F0</p:Property>
      <p:Property name="note">Separador dashed entre arcadas superior e inferior</p:Property>
    </p:Shape>

    <!-- Lower Arch (16 teeth: 48-41 | 31-38) -->
    <p:Shape type="Builtin:RoundedRect" id="arch_lower">
      <p:Property name="box">60,360,800,140</p:Property>
      <p:Property name="fillColor">#FFFFFF</p:Property>
      <p:Property name="note">Arcada inferior permanente. Layout invertido: silhueta em cima, grid no meio, numero embaixo.</p:Property>
    </p:Shape>
    <p:Shape type="Builtin:PlainText" id="teeth_lower_nums">
      <p:Property name="box">70,480,780,14</p:Property>
      <p:Property name="textContent">48   47   46   45   44   43   42   41   |   31   32   33   34   35   36   37   38</p:Property>
      <p:Property name="textFont">700 10px monospace</p:Property>
      <p:Property name="textColor">#64748B</p:Property>
      <p:Property name="textAlign">center</p:Property>
    </p:Shape>

    <!-- Arcada Decidua Title -->
    <p:Shape type="Builtin:PlainText" id="arc_kid_title">
      <p:Property name="box">60,520,200,16</p:Property>
      <p:Property name="textContent">Deciduos</p:Property>
      <p:Property name="textFont">700 12px sans-serif</p:Property>
      <p:Property name="textColor">#94A3B8</p:Property>
    </p:Shape>

    <!-- Deciduous upper (10 teeth: 55-51 | 61-65) -->
    <p:Shape type="Builtin:RoundedRect" id="arch_kid_upper">
      <p:Property name="box">160,540,600,120</p:Property>
      <p:Property name="fillColor">#FFFFFF</p:Property>
      <p:Property name="note">Arcada decidua superior. 10 dentes (55-51 | 61-65).</p:Property>
