    </p:Shape>
    <p:Shape type="Builtin:PlainText" id="mc_btn_reset_t">
      <p:Property name="box">210,290,150,20</p:Property>
      <p:Property name="textContent">Restaurar</p:Property>
      <p:Property name="textFont">500 13px sans-serif</p:Property>
      <p:Property name="textColor">#6B7280</p:Property>
      <p:Property name="textAlign">center</p:Property>
    </p:Shape>
  </Content>
</Page>

<!-- MOBILE: Kanban -->
<Page id="pg_mobile_kanban" name="11 - Kanban Mobile (375px)" width="375" height="812" backgroundColor="#F3F4F6"
      note="Responsivo mobile. Header 36px com hamburger. Script panel stacks acima do Kanban (colapsavel). Colunas em scroll horizontal. Cards com botoes empilhados. Filter panel toggleable.">
  <Content>
    <!-- Mobile Header -->
    <p:Shape type="Builtin:RoundedRect" id="mob_header">
      <p:Property name="box">0,0,375,40</p:Property>
      <p:Property name="fillColor">#FFFFFF</p:Property>
      <p:Property name="strokeColor">#E5E7EB</p:Property>
    </p:Shape>
    <p:Shape type="Builtin:PlainText" id="mob_hamburger">
      <p:Property name="box">10,10,24,20</p:Property>
      <p:Property name="textContent">[menu]</p:Property>
      <p:Property name="textFont">600 16px sans-serif</p:Property>
      <p:Property name="textColor">#1F2937</p:Property>
    </p:Shape>
    <p:Shape type="Builtin:PlainText" id="mob_clinic_name">
      <p:Property name="box">45,12,200,16</p:Property>
      <p:Property name="textContent">Clinica ABC</p:Property>
      <p:Property name="textFont">600 13px sans-serif</p:Property>
      <p:Property name="textColor">#1F2937</p:Property>
    </p:Shape>
    <p:Shape type="Builtin:Ellipse" id="mob_bell">
      <p:Property name="box">320,8,24,24</p:Property>
      <p:Property name="fillColor">#F3F4F6</p:Property>
      <p:Property name="strokeColor">#E5E7EB</p:Property>
    </p:Shape>

    <!-- Search bar -->
    <p:Shape type="Builtin:RoundedRect" id="mob_search">
      <p:Property name="box">10,50,355,36</p:Property>
      <p:Property name="fillColor">#FFFFFF</p:Property>
      <p:Property name="strokeColor">#D1D5DB</p:Property>
      <p:Property name="radius">6</p:Property>
    </p:Shape>

    <!-- Column scroll area -->
    <p:Shape type="Builtin:RoundedRect" id="mob_col1">
      <p:Property name="box">10,100,300,700</p:Property>
      <p:Property name="fillColor">#FFFFFF</p:Property>
      <p:Property name="strokeColor">#E5E7EB</p:Property>
      <p:Property name="radius">8</p:Property>
      <p:Property name="note">Colunas fazem scroll horizontal. Cada coluna full-width (300px). Swipe para navegar.</p:Property>
    </p:Shape>
    <p:Shape type="Builtin:RoundedRect" id="mob_col1_hd">
      <p:Property name="box">10,100,300,36</p:Property>
      <p:Property name="fillColor">#FAFAFA</p:Property>
      <p:Property name="radius">8</p:Property>
    </p:Shape>
    <p:Shape type="Builtin:PlainText" id="mob_col1_t">
      <p:Property name="box">20,108,100,20</p:Property>
      <p:Property name="textContent">Ligar</p:Property>
      <p:Property name="textFont">700 13px sans-serif</p:Property>
      <p:Property name="textColor">#1F2937</p:Property>
    </p:Shape>

    <!-- Mobile card (stacked buttons) -->
    <p:Shape type="Builtin:RoundedRect" id="mob_card">
      <p:Property name="box">18,145,284,360</p:Property>
      <p:Property name="fillColor">#FFFFFF</p:Property>
      <p:Property name="strokeColor">#E5E7EB</p:Property>
      <p:Property name="radius">8</p:Property>
      <p:Property name="shadow">true</p:Property>
      <p:Property name="note">Card mobile: botoes empilham verticalmente (flex-direction column). Height 36px cada botao. Mais espaco touch.</p:Property>
    </p:Shape>
  </Content>
</Page>

<!-- Bell Panel -->
<Page id="pg_bell_panel" name="12 - Painel Retornos" width="380" height="500" backgroundColor="#FFFFFF"
      note="Slide-in panel lateral direita. Lista de retornos agendados. Cada item: nome, horario, obs. Alerta visual (borda vermelha pulsante) para retornos vencidos.">
  <Content>
    <p:Shape type="Builtin:RoundedRect" id="bell_card">
      <p:Property name="box">0,0,380,500</p:Property>
      <p:Property name="fillColor">#FFFFFF</p:Property>
      <p:Property name="strokeColor">#E5E7EB</p:Property>
      <p:Property name="radius">12</p:Property>
      <p:Property name="shadow">true</p:Property>
    </p:Shape>

    <p:Shape type="Builtin:PlainText" id="bell_title">
      <p:Property name="box">20,20,300,20</p:Property>
      <p:Property name="textContent">[notifications_active] Retornos Agendados</p:Property>
      <p:Property name="textFont">600 15px sans-serif</p:Property>
      <p:Property name="textColor">#1F2937</p:Property>
    </p:Shape>

    <!-- Bell item 1 (overdue) -->
    <p:Shape type="Builtin:RoundedRect" id="bell_item1">
      <p:Property name="box">15,60,350,70</p:Property>
      <p:Property name="fillColor">#FEF2F2</p:Property>
      <p:Property name="strokeColor">#EF4444</p:Property>
      <p:Property name="radius">8</p:Property>
      <p:Property name="note">Item vencido: borda vermelha, fundo rosa, animacao pulse</p:Property>
    </p:Shape>
    <p:Shape type="Builtin:PlainText" id="bell_item1_nome">
      <p:Property name="box">25,68,200,16</p:Property>
      <p:Property name="textContent">Joao Pereira</p:Property>
      <p:Property name="textFont">600 13px sans-serif</p:Property>
      <p:Property name="textColor">#1F2937</p:Property>
    </p:Shape>
    <p:Shape type="Builtin:PlainText" id="bell_item1_time">
      <p:Property name="box">25,88,200,14</p:Property>
      <p:Property name="textContent">Hoje, 10:00 (ATRASADO)</p:Property>
      <p:Property name="textFont">500 11px sans-serif</p:Property>
      <p:Property name="textColor">#EF4444</p:Property>
    </p:Shape>
    <p:Shape type="Builtin:PlainText" id="bell_item1_obs">
      <p:Property name="box">25,106,300,14</p:Property>
      <p:Property name="textContent">Confirmar horario do implante</p:Property>
      <p:Property name="textFont">11px sans-serif</p:Property>
      <p:Property name="textColor">#6B7280</p:Property>
    </p:Shape>

    <!-- Bell item 2 (upcoming) -->
    <p:Shape type="Builtin:RoundedRect" id="bell_item2">
      <p:Property name="box">15,140,350,70</p:Property>
      <p:Property name="fillColor">#F8FAFC</p:Property>
      <p:Property name="strokeColor">#E2E8F0</p:Property>
      <p:Property name="radius">8</p:Property>
    </p:Shape>
    <p:Shape type="Builtin:PlainText" id="bell_item2_nome">
      <p:Property name="box">25,148,200,16</p:Property>
      <p:Property name="textContent">Ana Santos</p:Property>
      <p:Property name="textFont">600 13px sans-serif</p:Property>
      <p:Property name="textColor">#1F2937</p:Property>
    </p:Shape>
    <p:Shape type="Builtin:PlainText" id="bell_item2_time">
      <p:Property name="box">25,168,200,14</p:Property>
      <p:Property name="textContent">Hoje, 15:00</p:Property>
      <p:Property name="textFont">500 11px sans-serif</p:Property>
      <p:Property name="textColor">#6B7280</p:Property>
    </p:Shape>

    <!-- Bell item 3 -->
    <p:Shape type="Builtin:RoundedRect" id="bell_item3">
      <p:Property name="box">15,220,350,70</p:Property>
      <p:Property name="fillColor">#F8FAFC</p:Property>
      <p:Property name="strokeColor">#E2E8F0</p:Property>
      <p:Property name="radius">8</p:Property>
    </p:Shape>
    <p:Shape type="Builtin:PlainText" id="bell_item3_nome">
      <p:Property name="box">25,228,200,16</p:Property>
      <p:Property name="textContent">Carlos Lima</p:Property>
      <p:Property name="textFont">600 13px sans-serif</p:Property>
      <p:Property name="textColor">#1F2937</p:Property>
    </p:Shape>
    <p:Shape type="Builtin:PlainText" id="bell_item3_time">
      <p:Property name="box">25,248,200,14</p:Property>
      <p:Property name="textContent">Amanha, 09:00</p:Property>
      <p:Property name="textFont">500 11px sans-serif</p:Property>
      <p:Property name="textColor">#6B7280</p:Property>
    </p:Shape>
  </Content>
</Page>

</Document>
