      <p:Property name="strokeColor">#FECACA</p:Property>
      <p:Property name="radius">10</p:Property>
    </p:Shape>
    <p:Shape type="Builtin:PlainText" id="mres_opt3_t">
      <p:Property name="box">60,239,280,20</p:Property>
      <p:Property name="textContent">[cancel] Sem interesse</p:Property>
      <p:Property name="textFont">600 13px sans-serif</p:Property>
      <p:Property name="textColor">#DC2626</p:Property>
    </p:Shape>

    <!-- Option 4: Sem Resposta -->
